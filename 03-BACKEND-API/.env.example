# Copy to .env and fill in values for local development.
# In production (Cloud Run) these are set as environment variables on the service.

# ── BigQuery ───────────────────────────────────────────────────────────────────
# GCP project containing all datasets.
BIGQUERY_PROJECT=nfl-model-471509

# Optional: path to a service-account JSON key file.
# If unset, Application Default Credentials (ADC) are used.
# For local dev: run `gcloud auth application-default login` instead.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa-key.json

# ── API metadata ───────────────────────────────────────────────────────────────
API_VERSION=0.1.0

# Set at build time by CI/CD (Docker build-arg → ENV in container).
GIT_COMMIT=unknown

# ── Claude API (Step 5 — AI-assisted schema inference) ────────────────────────
# Required for POST /api/v1/datasets/{id}/infer-schema.
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optional: override the Claude model used for schema inference.
# Default: claude-haiku-4-5-20251001 (fast and cost-effective)
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Auth (Phase 3 — not enforced yet) ─────────────────────────────────────────
# OWNER_API_KEY=changeme

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=info
